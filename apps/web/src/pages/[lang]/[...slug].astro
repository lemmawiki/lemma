---
// Dynamic route for content-collection MDX pages.
//
//   URL                          → entry id
//   /en/modules/entropy          → modules/entropy/en
//   /ko/modules/entropy          → modules/entropy/ko
//   /en/finance/bitcoin-pizza    → applications/bitcoin-pizza/en  (mapping below)
//
// We use a small (kind, slug) → URL-path mapping so the URL can mirror the
// existing routing scheme (`/finance/bitcoin-pizza` lives under `applications/`
// in the collection but at `/<lang>/finance/...` in the URL).
import { getCollection, render } from "astro:content";
import Page from "../../layouts/page.astro";
import Breadcrumb from "../../components/page/breadcrumb.astro";
import GlossaryUsed from "../../components/page/glossary-used.astro";
import ProgressTracker from "../../components/page/progress-tracker.astro";
import { ProgressBanner } from "../../components/page/progress-banner";
import { moduleByHref } from "../../data/modules";
import { routeFromEntryId } from "../../lib/route-from-entry";
import { buildPageJsonLd } from "../../lib/page-jsonld";

export async function getStaticPaths() {
  const entries = await getCollection("pages");
  return entries
    .map((entry) => {
      const route = routeFromEntryId(entry.id);
      if (!route) return null;
      return {
        params: { lang: route.lang, slug: route.routePath },
        props: { entry, kind: route.kind, slug: route.slug },
      };
    })
    .filter((p): p is NonNullable<typeof p> => p !== null);
}

type Props = {
  entry: Awaited<ReturnType<typeof getCollection<"pages">>>[number];
  kind: string;
  slug: string;
};

const { entry, kind, slug } = Astro.props as Props;
const lang = (Astro.params.lang as "en" | "ko") ?? "en";

const { Content } = await render(entry);

// Structured metadata for the <head>. The same builder serves the per-page
// JSON-LD sidecar — HTML and JSON can't disagree about a page's metadata.
// includeBody=false keeps the inline JSON-LD tiny (no MDX prose duplication
// inside the script tag); the full body still lives at <page-url>.json.
const route = routeFromEntryId(entry.id);
const jsonLd = buildPageJsonLd({
  kind,
  slug,
  lang,
  url: route?.url ?? `/${lang}/${kind}/${slug}`,
  title: entry.data.title,
  description: entry.data.description ?? null,
  body: "",
  includeBody: false,
});

// Extract glossary term ids referenced anywhere in the body. Cheap regex over
// the MDX source; the GlossaryUsed component dedupes and order-preserves.
const termIds = Array.from((entry.body ?? "").matchAll(/<Term\s+[^>]*id=["']([^"']+)["']/g)).map(
  (m) => m[1],
);

// Default breadcrumb: pages under modules/applications get a "graph" parent.
const isModule = kind === "modules";
const isApp = kind === "applications";
const breadcrumb = entry.data.breadcrumb ?? {
  parent_path: isModule || isApp ? "/graph" : undefined,
  parent: isModule || isApp ? (lang === "ko" ? "그래프" : "graph") : undefined,
  current:
    isModule && moduleByHref[`/modules/${slug}`]
      ? lang === "ko"
        ? `모듈 · ${moduleByHref[`/modules/${slug}`].title.ko}`
        : `module · ${moduleByHref[`/modules/${slug}`].title.en.toLowerCase()}`
      : entry.data.title,
};
---

<Page lang={lang} title={entry.data.title} description={entry.data.description} jsonLd={jsonLd}>
  <Breadcrumb
    lang={lang}
    parent={
      breadcrumb.parent && breadcrumb.parent_path
        ? { href: breadcrumb.parent_path, label: breadcrumb.parent }
        : undefined
    }
  >
    {breadcrumb.current}
  </Breadcrumb>

  <ProgressBanner language={lang} client:load />

  <Content />

  {termIds.length > 0 && <GlossaryUsed lang={lang} ids={termIds} />}

  <ProgressTracker />
</Page>
