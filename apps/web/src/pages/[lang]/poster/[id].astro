---
// Print-ready poster for one module.
//
// Layout: A3 portrait (297mm × 420mm). On screen, scaled to fit the
// viewport so authors can preview without scrolling. On print, exact A3 —
// `@page { size: A3 portrait; margin: 0; }` and no chrome.
//
// Workflow:
//   1. Visit /<lang>/poster/<module-id>/ to preview.
//   2. Cmd+P → Save as PDF, choose A3, no margins.
//   3. Print on A3 paper for the wall, or share the PDF.
import "../../../styles/global.css";
import { posters, posterById } from "../../../data/posters";
import { moduleByHref } from "../../../data/modules";
import { glossaryById } from "../../../data/glossary";

export function getStaticPaths() {
  const out: { params: { lang: string; id: string } }[] = [];
  for (const p of posters) {
    out.push({ params: { lang: "en", id: p.id } });
    out.push({ params: { lang: "ko", id: p.id } });
  }
  return out;
}

const lang = (Astro.params.lang as "en" | "ko") ?? "en";
const id = Astro.params.id as string;
const poster = posterById[id];

if (!poster) {
  return Astro.redirect(`/${lang}/`);
}

const mod = moduleByHref[`/modules/${id}`];
const moduleTitle = mod?.title[lang] ?? id;

const url = `lemma.wiki${Astro.url.pathname.replace(/\/poster\/.*$/, `/modules/${id}`)}`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>Poster · {moduleTitle} · Lemma</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <style>
      :root {
        /* A3 portrait — 297 mm × 420 mm. */
        --poster-w: 297mm;
        --poster-h: 420mm;
        --ink: #1a1815;
        --ink-soft: #3b3933;
        --ink-mute: #79766f;
        --acc: #b6451e;
        --acc-deep: #8c3416;
        --rule: #d8d2c5;
        --rule-soft: #ece7da;
        --bg: #f8f5ee;
      }

      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        background: #2a2825;
        color: var(--ink);
        font-family: "Fraunces", serif;
        min-height: 100vh;
        display: flex;
        align-items: flex-start;
        justify-content: center;
        padding: 24px 16px;
      }

      .frame {
        display: flex;
        align-items: center;
        justify-content: center;
        /* Scale the A3 page to fit viewport. */
        transform: scale(min(calc((100vw - 48px) / (297 * 3.7795)), calc((100vh - 96px) / (420 * 3.7795))));
        transform-origin: top center;
      }

      .poster {
        width: var(--poster-w);
        height: var(--poster-h);
        background: var(--bg);
        position: relative;
        overflow: hidden;
        padding: 24mm 22mm;
        display: grid;
        grid-template-rows: auto auto 1fr auto auto;
        gap: 8mm;
        font-feature-settings: "lnum";
      }

      .header {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        font-family: "JetBrains Mono", monospace;
        font-size: 11pt;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--ink-mute);
      }
      .header .brand {
        font-weight: 600;
        color: var(--acc);
      }

      .punchline {
        font-family: "Fraunces", serif;
        font-weight: 600;
        font-size: 28pt;
        line-height: 1.05;
        letter-spacing: -0.015em;
        color: var(--ink);
        margin: 4mm 0 0 0;
        max-width: 22ch;
      }
      .punchline.ko {
        font-family: "Diphylleia", "Fraunces", serif;
        font-weight: 400;
      }

      .formula-block {
        align-self: center;
        text-align: center;
        padding: 8mm 0;
      }
      .formula {
        font-family: "JetBrains Mono", monospace;
        font-size: 56pt;
        line-height: 1.1;
        letter-spacing: -0.02em;
        color: var(--acc-deep);
        font-weight: 500;
      }

      .one-line {
        font-family: "Fraunces", serif;
        font-size: 13pt;
        line-height: 1.55;
        color: var(--ink-soft);
        max-width: 60ch;
        border-left: 4px solid var(--acc);
        padding: 2mm 0 2mm 6mm;
        font-style: italic;
      }
      .one-line em {
        color: var(--acc-deep);
      }

      .terms {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(40mm, 1fr));
        gap: 4mm;
      }
      .term-card {
        padding: 4mm 5mm;
        border: 1px solid var(--rule);
        border-radius: 2mm;
        background: var(--rule-soft);
      }
      .term-card .term-name {
        font-family: "Fraunces", serif;
        font-weight: 600;
        font-size: 13pt;
        color: var(--ink);
        margin-bottom: 1.5mm;
        letter-spacing: -0.01em;
      }
      .term-card .term-name.ko {
        font-family: "Diphylleia", "Fraunces", serif;
        font-weight: 400;
      }
      .term-card .term-counterpart {
        font-family: "JetBrains Mono", monospace;
        font-size: 9pt;
        color: var(--ink-mute);
        text-transform: lowercase;
        letter-spacing: 0.04em;
      }

      .footer {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        border-top: 1px solid var(--rule);
        padding-top: 4mm;
        font-family: "JetBrains Mono", monospace;
        font-size: 9pt;
        color: var(--ink-mute);
        letter-spacing: 0.04em;
      }

      /* Big seed mark in the corner — homage to "Look closer." */
      .leaf {
        position: absolute;
        right: -20mm;
        bottom: -20mm;
        width: 110mm;
        height: 110mm;
        opacity: 0.06;
        pointer-events: none;
      }

      /* Print: A3 portrait, no margins, no body background. */
      @media print {
        @page {
          size: A3 portrait;
          margin: 0;
        }
        body {
          background: white;
          padding: 0;
          display: block;
        }
        .frame {
          transform: none;
        }
        .poster {
          box-shadow: none;
        }
        .preview-tip {
          display: none;
        }
      }

      /* Screen-only preview hint */
      .preview-tip {
        position: fixed;
        top: 12px;
        left: 12px;
        right: 12px;
        text-align: center;
        font-family: "JetBrains Mono", monospace;
        font-size: 12px;
        color: #ccc;
        opacity: 0.6;
        pointer-events: none;
      }
    </style>
  </head>
  <body>
    <div class="preview-tip">Cmd+P → Save as PDF · A3 portrait · no margins</div>

    <div class="frame">
      <div class="poster">
        <div class="header">
          <div class="brand">Lemma</div>
          <div>module · {id}</div>
        </div>

        <h1 class={`punchline ${lang}`}>{poster.punchline[lang]}</h1>

        <div class="formula-block">
          <div class="formula">{poster.formula}</div>
        </div>

        <div class="one-line">{poster.oneLine[lang]}</div>

        <div class="terms">
          {
            poster.terms.map((tid) => {
              const t = glossaryById[tid];
              if (!t) return null;
              const en = t.locales.en?.term ?? tid;
              const ko = t.locales.ko?.term ?? tid;
              const primary = lang === "en" ? en : ko;
              const counter = lang === "en" ? ko : en;
              return (
                <div class="term-card">
                  <div class={`term-name ${lang}`}>{primary}</div>
                  <div class="term-counterpart">{counter}</div>
                </div>
              );
            })
          }
        </div>

        <div class="footer">
          <div>{url}</div>
          <div>cc by 4.0 · {lang.toUpperCase()}</div>
        </div>

        <svg
          class="leaf"
          viewBox="0 0 100 100"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          stroke="currentColor"
          stroke-width="1"
        >
          <path d="M 50 10 Q 80 30 70 70 Q 50 95 30 70 Q 20 30 50 10 Z" />
          <line x1="50" y1="10" x2="50" y2="90" />
        </svg>
      </div>
    </div>
  </body>
</html>
