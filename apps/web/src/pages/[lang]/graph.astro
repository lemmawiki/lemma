---
// Locale-prefixed graph hub (`/en/graph`, `/ko/graph`). Mounts the existing
// React Graph view inside the new locale-aware Page layout. The graph is a
// computed view over applications.ts × modules.ts; not MDX content.
import Page from "../../layouts/page.astro";
import GraphIsland from "../../views/graph-island.tsx";

export function getStaticPaths() {
  return [{ params: { lang: "en" } }, { params: { lang: "ko" } }];
}

const lang = (Astro.params.lang as "en" | "ko") ?? "en";
const title = lang === "ko" ? "그래프 · Lemma" : "Graph · Lemma";
const description =
  lang === "ko"
    ? "Lemma 매니페스토가 약속하는 모듈 그래프 — 진짜 엣지로 그린다."
    : "The modular graph the Lemma manifesto promises — drawn honestly.";
---

<Page lang={lang} title={title} description={description}>
  <GraphIsland language={lang} client:load />
</Page>
