---
const lang: "en" | "ko" = (Astro.currentLocale as "en" | "ko" | undefined) ?? "en";
const label = lang === "ko" ? "이제 깨봐" : "now break it";
---

<div
  class="mt-4 rounded-r-md border-l-[3px] border-dashed border-acc-deep bg-acc-soft/40 px-4 py-3 text-[14.5px] leading-[1.55] text-ink-soft [&_strong]:font-semibold [&_strong]:text-ink [&_em]:italic [&_em]:text-acc-deep [&_p]:m-0"
>
  <div class="mb-1 font-mono text-[11px] uppercase tracking-[0.08em] text-acc-deep">{label}</div>
  <div><slot /></div>
</div>
