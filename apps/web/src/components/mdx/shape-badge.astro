---
// <ShapeBadge id="find-the-minimum" /> — inline pointer from an
// application page to the shape it's an instance of.
//
// Usage inside an application's MDX:
//   <ShapeBadge id="equilibrium" />
//
// Renders a small "this page is one of N instances of <shape>"
// affordance that links to the shape page. The shape page is where
// the side-by-side comparison lives — this badge is just a doorway.

import { shapeById } from "../../data/shapes";

interface Props {
  id: string;
}

const { id } = Astro.props;
const lang: "en" | "ko" = (Astro.currentLocale as "en" | "ko" | undefined) ?? "en";
const shape = shapeById[id];

const labels = {
  en: {
    instanceOf: "instance of",
    seeAll: "see all instances →",
  },
  ko: {
    instanceOf: "이 골격의 인스턴스",
    seeAll: "전체 인스턴스 보기 →",
  },
}[lang];
---

{
  shape && (
    <aside class="my-6 rounded-md border border-rule bg-rule-soft px-4 py-3 font-sans text-[14px]">
      <div class="mb-1 font-mono text-[10.5px] uppercase tracking-[0.06em] text-ink-mute">
        {labels.instanceOf}
      </div>
      <a
        href={`/${lang}/shapes/${id}`}
        class="font-serif text-[16px] font-semibold text-ink no-underline hover:text-acc"
      >
        {shape.title[lang] ?? shape.title.en}
      </a>
      <p class="m-0 mt-1 text-[13.5px] leading-[1.5] text-ink-soft">
        {shape.hook[lang] ?? shape.hook.en}
      </p>
      <a
        href={`/${lang}/shapes/${id}`}
        class="mt-2 inline-block font-mono text-[11px] uppercase tracking-[0.06em] text-acc no-underline hover:underline"
      >
        {labels.seeAll}
      </a>
    </aside>
  )
}
